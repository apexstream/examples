# ─── Gateway WebSocket (browser publishes here) ───
VITE_APEXSTREAM_WS_URL=ws://localhost:8081/v1/ws
VITE_APEXSTREAM_API_KEY=

# Local / LAN: ws:// in URL is enough; set 1 to document dev mode or if your setup needs an explicit flag
VITE_APEXSTREAM_ALLOW_INSECURE=1

# ─── Control Plane HTTP (External API: register webhooks, poll deliveries) ───
# In dev, Vite proxies /apex-api → this URL (must be where POST /external/v1/* is served).
# Example: stack on one machine — gateway WS :30081, API HTTP :8080:
# VITE_CONTROL_PLANE_URL=http://192.168.0.139:8080
VITE_CONTROL_PLANE_URL=http://localhost:8080

# Override proxy target only if URL differs from Control Plane URL (rare):
# VITE_CONTROL_PLANE_PROXY_TARGET=http://192.168.0.139:8080

# Same secret as API env APEXSTREAM_EXTERNAL_API_KEY (required for External API routes)
VITE_EXTERNAL_API_KEY=

# ─── Form defaults (optional) ───
# Project ID is auto-filled from VITE_APEXSTREAM_API_KEY via POST /external/v1/keys/resolve when the page loads (must match this app).
VITE_PROJECT_ID=
VITE_WEBHOOK_TARGET_URL=http://127.0.0.1:8787/webhook
VITE_WEBHOOK_SECRET=whsec_demo
