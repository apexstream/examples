# Node reads this file automatically (publish.mjs).
# You can use either APEXSTREAM_* or copy the same VITE_* lines from ../client/.env.

# Gateway WebSocket URL
APEXSTREAM_WS_URL=ws://localhost:8081/v1/ws
# or: VITE_APEXSTREAM_WS_URL=ws://localhost:8081/v1/ws

# API key (publishable pk_live_… or secret sk_live_…)
APEXSTREAM_API_KEY=
# or: VITE_APEXSTREAM_API_KEY=

# Channel name (must match dashboard subscription)
APEXSTREAM_METRICS_CHANNEL=metrics

# Optional: explicit dev/LAN; ws:// in APEXSTREAM_WS_URL already enables insecure transport in publish.mjs
# APEXSTREAM_ALLOW_INSECURE_TRANSPORT=1

# Publish interval in ms (default 300 if unset — faster “live” updates)
# Try 150–250 for very snappy demos; gateway rate limits still apply.
APEXSTREAM_PUBLISH_INTERVAL_MS=300
