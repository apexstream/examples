# WebSocket base URL (no query; client appends api_key)
VITE_APEXSTREAM_WS_URL=ws://localhost:8081/v1/ws

# Same publishable key as the publisher (or read-only subscriber key)
VITE_APEXSTREAM_API_KEY=

# Optional: explicit local/LAN dev (http:// page + ws:// gateway); code also enables from ws:// URL
# VITE_APEXSTREAM_ALLOW_INSECURE=1

# Channel (default: metrics)
# VITE_APEXSTREAM_METRICS_CHANNEL=metrics
