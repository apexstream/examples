VITE_APEXSTREAM_WS_URL=ws://127.0.0.1:8081/v1/ws
VITE_APEXSTREAM_API_KEY=

# Optional: explicit dev (http:// + ws://); ws:// in URL already enables insecure transport in the SDK
# VITE_APEXSTREAM_ALLOW_INSECURE=1

# Channel segment: chat:<room>
VITE_CHAT_ROOM=general

# Display name when connecting (optional)
VITE_CHAT_USER=dev-user
