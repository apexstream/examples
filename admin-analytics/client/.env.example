# Control Plane HTTP base (Browser uses Vite proxy `/apex-api` → this URL in dev.)
VITE_CONTROL_PLANE_URL=http://localhost:8080

# Same value as API env APEXSTREAM_EXTERNAL_API_KEY (required for External API routes)
VITE_EXTERNAL_API_KEY=

# Same sk_live… app key as Demo 3 / chat — used to auto-fill Project ID (POST /external/v1/keys/resolve).
# VITE_APEXSTREAM_API_KEY=

# Project scope for webhook tables (MongoDB id). If wrong, webhook rows stay empty — prefer auto-fill via key above.
# VITE_PROJECT_ID=

# Optional dev proxy override (LAN / Docker):
# VITE_CONTROL_PLANE_PROXY_TARGET=http://192.168.1.10:8080

# Poll interval ms (default 2500)
# VITE_POLL_INTERVAL_MS=2500
