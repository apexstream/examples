VITE_APEXSTREAM_WS_URL=ws://127.0.0.1:8081/v1/ws
VITE_APEXSTREAM_API_KEY=

# ws:// to a LAN / k8s NodePort (not 127.0.0.1)? The client allows it when the URL uses ws://.
# If the *browser page* is on a different host than the gateway (e.g. open http://192.168.0.251:5178
# but WS is ws://127.0.0.1:30081/...), the gateway may reject the Upgrade unless you set:
#   APEXSTREAM_GATEWAY_ALLOW_ORIGINS=*
# or a comma-separated list of full origins (http://HOST:5178,...) on the gateway Pod.

# Shared session — same id = same bus (`agents:<session>:events`)
VITE_AGENTS_SESSION=local-session

# LLM backend: omit or `ollama` (default). Set `cursor` to start on Cursor Cloud Agents UI.
# VITE_LLM_BACKEND=cursor

# --- Ollama (local streaming)
# Default model (must exist in `ollama list`; UI refreshes models from Ollama)
VITE_OLLAMA_MODEL=llama3.2

# Production / custom Ollama URL (defaults: dev uses Vite proxy → 127.0.0.1:11434; prod uses http://127.0.0.1:11434)
# VITE_OLLAMA_URL=http://127.0.0.1:11434

# --- Cursor Cloud Agents API (https://api.cursor.com — GitHub repo job; not OpenAI-style chat)
# Key from Cursor Dashboard (Basic auth: key as username, empty password)
# VITE_CURSOR_API_KEY=
# Public GitHub repo URL the agent can access
# VITE_CURSOR_REPO=https://github.com/org/repo
# VITE_CURSOR_REF=main
# Optional explicit model id from GET /v0/models, or use UI "default"
# VITE_CURSOR_MODEL=default
# Production: **your** reverse-proxy base that forwards to Cursor — do NOT use https://api.cursor.com here
# (browser CORS). Leave unset to use same-origin `/api/cursor` (requires nginx/gateway proxy in prod).
# VITE_CURSOR_API_URL=https://your-api.example.com/cursor-proxy
