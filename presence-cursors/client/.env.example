VITE_APEXSTREAM_WS_URL=ws://127.0.0.1:8081/v1/ws
VITE_APEXSTREAM_API_KEY=

# Optional: explicit dev/LAN (see packages/client README); ws:// in URL already enables insecure transport
# VITE_APEXSTREAM_ALLOW_INSECURE=1

# Shared space: messages go to channel cursors:<room>
VITE_CURSOR_ROOM=demo-room

# Label shown to other participants (optional)
VITE_CURSOR_USER=guest-100
